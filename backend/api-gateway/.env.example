# ════════════════════════════════════════════════════════════════════════════
# Study Buddy API Gateway - Environment Configuration
# ════════════════════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# ── PostgreSQL (User Data) ──────────────────────────────────────────────────
# Install: docker run --name studybuddy-postgres -e POSTGRES_PASSWORD=yourpassword -p 5432:5432 -d postgres:15
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=studybuddy
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=studybuddy_users

# PostgreSQL Connection String (alternative)
# DATABASE_URL=postgresql://studybuddy:yourpassword@localhost:5432/studybuddy_users

# ── MongoDB (Content - Study Materials, Quizzes) ────────────────────────────
# Install: docker run --name studybuddy-mongo -p 27017:27017 -d mongo:6
MONGODB_URI=mongodb://localhost:27017/studybuddy_content

# ── Redis (Cache, Sessions, Rate Limiting) ──────────────────────────────────
# Install: docker run --name studybuddy-redis -p 6379:6379 -d redis:7
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT Configuration ───────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_REFRESH_EXPIRATION=7d

# ── ML Service (FastAPI) ────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000/api/v1

# ── Google Gemini API ──────────────────────────────────────────────────────
# Optional: Proxy Gemini requests through backend to hide API key
GEMINI_API_KEY=AIzaSyB-ldUVNrHndQ84LblWey6kg7fZxGAglOk
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Firebase Cloud Messaging ────────────────────────────────────────────────
# Optional: For push notifications
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your-private-key

# ── Rate Limiting ───────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:8080,http://localhost:3001

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
